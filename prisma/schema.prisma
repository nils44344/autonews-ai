// Schema reset — wiped 2026-06-08 for new business pivot. Keep Prisma wired
// so the next build can iterate fast without redoing infra.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Minimal placeholder so prisma generate doesn't fail. Replace with real
// models once the new product direction is decided.
model JobLog {
  id        String   @id @default(cuid())
  job       String
  status    String
  message   String?  @db.Text
  meta      Json?
  createdAt DateTime @default(now())

  @@index([job, createdAt])
}
