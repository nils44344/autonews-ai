// AutoNews AI — data model
// PostgreSQL + Prisma. Run `npm run db:push` (or db:migrate) to apply.

generator client {
  provider      = "prisma-client-js"
  // "native" covers local dev + the build machine; the rhel targets cover
  // serverless runtimes (Netlify/AWS Lambda) so the deployed functions can
  // find a matching Prisma query engine.
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Content taxonomy ─────────────────────────────────────────────────────────

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  kind      String    @default("news") // news | blog | meme
  articles  Article[]
  memes     Meme[]
  createdAt DateTime  @default(now())
}

model Tag {
  id       String       @id @default(cuid())
  name     String       @unique
  slug     String       @unique
  articles ArticleTag[]
}

// ── Trend detection ──────────────────────────────────────────────────────────

enum SourceType {
  RSS
  REDDIT
  GOOGLE_TRENDS
  GOOGLE_NEWS
  HACKERNEWS
  NEWSAPI
  YOUTUBE
  X
}

model Source {
  id          String        @id @default(cuid())
  type        SourceType
  name        String
  url         String? // feed url / subreddit / query
  category    String        @default("general")
  enabled     Boolean       @default(true)
  weight      Float         @default(1.0) // trust/importance multiplier
  lastFetched DateTime?
  lastStatus  String? // ok | error:<msg>
  signals     TrendSignal[]
  createdAt   DateTime      @default(now())

  @@unique([type, url])
}

// A raw observation pulled from a source (one headline / post / query).
model TrendSignal {
  id         String      @id @default(cuid())
  source     Source      @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  sourceId   String
  title      String
  url        String?
  summary    String?     @db.Text
  score      Float       @default(0) // raw popularity from the source (upvotes, rank...)
  raw        Json?
  topic      TrendTopic? @relation(fields: [topicId], references: [id])
  topicId    String?
  observedAt DateTime    @default(now())

  @@index([observedAt])
  @@index([sourceId])
}

enum TopicStatus {
  DETECTED // freshly clustered
  RANKED // scored & ranked
  SELECTED // chosen for generation
  GENERATING
  GENERATED
  REJECTED
  PUBLISHED
}

// A clustered, dedup'd topic aggregated from many signals.
model TrendTopic {
  id       String      @id @default(cuid())
  title    String
  slug     String      @unique
  category String      @default("general")
  keywords String[]
  status   TopicStatus @default(DETECTED)

  // Scoring (0-100 each)
  viralScore       Float @default(0)
  seoScore         Float @default(0)
  freshnessScore   Float @default(0)
  competitionScore Float @default(0) // higher = LOWER competition (more opportunity)
  finalScore       Float @default(0)

  sourceCount Int     @default(1)
  isBreaking  Boolean @default(false)

  signals  TrendSignal[]
  articles Article[]
  memes    Meme[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([finalScore])
  @@index([status])
}

// ── Articles (news + blog) ───────────────────────────────────────────────────

enum ArticleType {
  NEWS
  BLOG
}

enum ArticleStatus {
  DRAFT
  REVIEW // waiting for manual approval
  SCHEDULED
  PUBLISHED
  REJECTED
}

model Article {
  id     String        @id @default(cuid())
  type   ArticleType   @default(NEWS)
  status ArticleStatus @default(DRAFT)

  title   String
  slug    String  @unique
  dek     String? @db.Text // standfirst / subtitle
  body    String  @db.Text // markdown
  excerpt String? @db.Text

  // SEO
  seoTitle       String?
  seoDescription String?  @db.Text
  keywords       String[]
  canonicalUrl   String?
  faq            Json? // [{question, answer}]
  sources        Json? // [{title, url}] external citations
  ogImage        String?
  imageCredit    String? // attribution for CC/Wikimedia images (legally required)
  factCheck      Json? // {claimReviewed, rating, verdict} for fact-check pieces

  // Quality
  qualityScore  Float @default(0)
  qualityReport Json?
  wordCount     Int   @default(0)
  readingMin    Int   @default(0)

  // Relations
  category   Category?    @relation(fields: [categoryId], references: [id])
  categoryId String?
  topic      TrendTopic?  @relation(fields: [topicId], references: [id])
  topicId    String?
  tags       ArticleTag[]
  clusterId  String? // topic-cluster id linking pillar + supporting posts
  isPillar   Boolean      @default(false)

  // Internal linking (self-referential many-to-many)
  linksOut ArticleLink[] @relation("from")
  linksIn  ArticleLink[] @relation("to")

  publishedAt  DateTime?
  scheduledFor DateTime?
  views        Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status, type])
  @@index([publishedAt])
  @@index([clusterId])
}

model ArticleTag {
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId     String

  @@id([articleId, tagId])
}

model ArticleLink {
  from   Article @relation("from", fields: [fromId], references: [id], onDelete: Cascade)
  fromId String
  to     Article @relation("to", fields: [toId], references: [id], onDelete: Cascade)
  toId   String
  anchor String

  @@id([fromId, toId])
}

// ── Opportunities (Pillar 1 — the moat) ──────────────────────────────────────
// An AI Opportunity is an actionable thing a user can build, sell, or monetize.
// It is NOT a news article. News supports opportunities; opportunities are the
// product. Score is computed from demand/growth/competition/monetization so we
// can rank them on the homepage and in the /opportunities feed.

enum OpportunityKind {
  BUSINESS // standalone business idea
  STARTUP // venture-scale opportunity
  AUTOMATION // workflow/automation play
  CREATOR // content/creator angle
  AGENCY // service business
  NICHE // small but profitable niche
  MONETIZATION // way to monetize existing audience/skill
}

enum OpportunityStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Opportunity {
  id     String            @id @default(cuid())
  slug   String            @unique
  title  String
  kind   OpportunityKind   @default(BUSINESS)
  status OpportunityStatus @default(DRAFT)

  // Editorial fields
  summary           String   @db.Text // one-paragraph TL;DR
  whyItMatters      String   @db.Text // why now, why this
  marketContext     String?  @db.Text // demand signals, search trends
  implementation    String?  @db.Text // how to actually start
  monetizationPaths Json? // [{path, model, revenueRange}]
  recommendedTools  Json? // [{name, url, why}]
  relatedWorkflows  Json? // [{title, url}]
  relatedArticleIds String[] // links to NEWS articles that surfaced this

  // Scoring inputs (0-100 each)
  demandScore       Float @default(50)
  growthScore       Float @default(50)
  competitionScore  Float @default(50) // higher = MORE competition (worse)
  monetizationScore Float @default(50)
  difficultyScore   Float @default(50) // higher = HARDER to execute

  // Computed (denormalized for fast sort): see lib/opportunity-score.ts
  opportunityScore Float @default(0)

  // SEO
  seoTitle       String?
  seoDescription String?  @db.Text
  keywords       String[]
  ogImage        String?

  views       Int       @default(0)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, opportunityScore])
  @@index([publishedAt])
  @@index([kind])
}

// ── Tools (Pillar 3 — the SEO engine) ────────────────────────────────────────
// Curated AI tools with editorial context — never a passive directory. Every
// entry must answer: why this matters, what opportunity it unlocks, who should
// use it. Comparisons + rankings come from this table.

enum ToolPricingModel {
  FREE
  FREEMIUM
  PAID
  SUBSCRIPTION
  USAGE
  ENTERPRISE
}

enum ToolStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Tool {
  id             String           @id @default(cuid())
  slug           String           @unique
  name           String
  vendor         String?
  url            String?
  status         ToolStatus       @default(DRAFT)

  tagline        String
  overview       String           @db.Text
  whyItMatters   String           @db.Text
  useCases       Json?            // ["case 1", "case 2"]
  pros           Json?            // ["pro 1", ...]
  cons           Json?            // ["con 1", ...]
  pricing        ToolPricingModel @default(FREEMIUM)
  pricingNotes   String?
  categories     String[]         // ["writing", "code", "voice", ...]
  alternatives   String[]         // slugs of competing tools

  // Momentum (0-100). Used by "fastest growing" widgets on the homepage.
  // Refreshed periodically by a scoring job or hand-tuned by editors.
  popularityScore Float            @default(50)
  momentumScore   Float            @default(50)
  trendingScore   Float            @default(50)
  ranking         Int?             // global rank; null = unranked

  seoTitle       String?
  seoDescription String?           @db.Text
  keywords       String[]
  logoUrl        String?
  ogImage        String?

  views          Int               @default(0)
  publishedAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([status, momentumScore])
  @@index([categories])
}

// ── Workflows (Pillar 4 — the retention engine) ──────────────────────────────
// A practical, replicable system that stacks 2+ tools to produce an outcome.
// Each workflow specifies tools used, steps, expected results, time saved.

enum WorkflowKind {
  CREATOR
  BUSINESS
  AUTOMATION
  DEVELOPER
  MARKETING
  TRADING
  RESEARCH
}

enum WorkflowStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Workflow {
  id              String          @id @default(cuid())
  slug            String          @unique
  title           String
  kind            WorkflowKind    @default(BUSINESS)
  status          WorkflowStatus  @default(DRAFT)

  objective       String          @db.Text
  toolsRequired   Json?           // [{name, url, role}]
  steps           Json?           // [{title, detail}] — ordered
  automationMap   String?         @db.Text // optional textual diagram (mermaid-ish)
  expectedResults String?         @db.Text
  timeSavedHours  Float           @default(0)
  difficultyScore Float           @default(50) // 0-100, higher = harder

  // For homepage "Trending Workflows"
  popularityScore Float           @default(50)

  seoTitle        String?
  seoDescription  String?         @db.Text
  keywords        String[]
  ogImage         String?

  views           Int             @default(0)
  publishedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([status, popularityScore])
  @@index([kind])
}

// ── Startup Radar (Pillar 5) ─────────────────────────────────────────────────
// Tracked AI startups with funding, momentum, breakout indicators. NOT
// Crunchbase scale — curated to surface companies the user should know about
// before they're obvious.

enum StartupStage {
  PRESEED
  SEED
  SERIES_A
  SERIES_B
  SERIES_C_PLUS
  PUBLIC
  ACQUIRED
  BOOTSTRAPPED
}

enum StartupStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Startup {
  id              String         @id @default(cuid())
  slug            String         @unique
  name            String
  url             String?
  status          StartupStatus  @default(DRAFT)

  tagline         String
  description     String         @db.Text
  whyItMatters    String         @db.Text
  category        String         // "voice-ai", "code-ai", "infra", ...
  hq              String?        // city/country
  founded         Int?           // year
  stage           StartupStage   @default(SEED)
  totalRaisedUsd  Float?         // millions
  lastRoundUsd    Float?         // millions
  lastRoundDate   DateTime?
  investors       String[]
  signals         Json?          // [{label, value, direction}] arbitrary growth signals

  // Computed/curated 0-100
  momentumScore   Float          @default(50)
  isBreakout      Boolean        @default(false)

  seoTitle        String?
  seoDescription  String?        @db.Text
  keywords        String[]
  logoUrl         String?
  ogImage         String?

  views           Int            @default(0)
  publishedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([status, momentumScore])
  @@index([category])
}

// ── Signals (Pillar 2 — live intelligence feed) ──────────────────────────────
// A Signal is a discrete "what's exploding right now" event: a launch, a viral
// post, a star burst on a GitHub repo, a funding rumor. Distinct from
// TrendSignal (which feeds the news engine). Each Signal can link to a Tool /
// Startup / Opportunity so users can act on it.

enum SignalKind {
  LAUNCH
  FUNDING
  GROWTH       // star burst, follower spike, etc.
  VIRAL_POST
  RESEARCH     // paper / breakthrough
  HIRING
  ACQUISITION
}

enum SignalStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Signal {
  id              String         @id @default(cuid())
  slug            String         @unique
  title           String
  kind            SignalKind     @default(LAUNCH)
  status          SignalStatus   @default(DRAFT)

  summary         String         @db.Text
  sourceUrl       String?
  sourceLabel     String?        // "Product Hunt", "Hacker News", "Twitter/X", ...

  // Scoring (0-100). momentum = how fast it's growing; reach = how big the
  // audience is now; opportunity = how actionable for our users.
  momentumScore   Float          @default(50)
  reachScore      Float          @default(50)
  opportunityScore Float         @default(50)
  isHot           Boolean        @default(false) // editor or job-promoted

  // Optional links into other pillars so a Signal turns into action.
  toolSlug        String?
  startupSlug     String?
  opportunitySlug String?

  observedAt      DateTime       @default(now())
  publishedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([status, observedAt])
  @@index([momentumScore])
}

// ── Memes ────────────────────────────────────────────────────────────────────

enum MemeStatus {
  DRAFT
  REVIEW
  PUBLISHED
  REJECTED
}

model Meme {
  id           String      @id @default(cuid())
  status       MemeStatus  @default(DRAFT)
  title        String
  slug         String      @unique
  format       String // e.g. "Drake", "Distracted Boyfriend", "two-panel"
  topText      String?
  bottomText   String?
  caption      String?     @db.Text // social-share caption
  imagePrompt  String      @db.Text // AI image generation prompt
  imageUrl     String? // populated once an image is rendered
  category     Category?   @relation(fields: [categoryId], references: [id])
  categoryId   String?
  topic        TrendTopic? @relation(fields: [topicId], references: [id])
  topicId      String?
  safetyScore  Float       @default(0) // 0-100, higher = safer
  safetyReport Json?
  publishedAt  DateTime?
  createdAt    DateTime    @default(now())

  @@index([status])
}

// ── Monetization (architecture-ready) ────────────────────────────────────────

model NewsletterSubscriber {
  id         String   @id @default(cuid())
  email      String   @unique
  confirmed  Boolean  @default(false)
  unsubToken String   @unique @default(cuid())
  topics     String[] // interest tags
  createdAt  DateTime @default(now())
}

model AffiliateLink {
  id       String   @id @default(cuid())
  name     String
  url      String
  network  String // amazon | impact | shareasale | custom
  keywords String[] // auto-insert when these keywords appear in content
  clicks   Int      @default(0)
  enabled  Boolean  @default(true)
}

model SponsoredPost {
  id          String    @id @default(cuid())
  advertiser  String
  articleId   String?
  budgetCents Int       @default(0)
  startAt     DateTime?
  endAt       DateTime?
  active      Boolean   @default(false)
}

// Aggregated daily revenue/traffic snapshot for the dashboard.
model DailyStat {
  id             String   @id @default(cuid())
  date           DateTime @unique @db.Date
  pageViews      Int      @default(0)
  uniqueVisitors Int      @default(0)
  articles       Int      @default(0)
  adRevenueCents Int      @default(0)
  affiliateCents Int      @default(0)
  createdAt      DateTime @default(now())
}

// ── Ops / audit ──────────────────────────────────────────────────────────────

model JobLog {
  id        String   @id @default(cuid())
  job       String // queue/job name
  status    String // started | ok | error
  message   String?  @db.Text
  meta      Json?
  createdAt DateTime @default(now())

  @@index([job, createdAt])
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
}
