# ─────────────────────────────────────────────────────────────────────────────
# AutoNews AI — environment configuration
# Copy to `.env` and fill in. The MVP runs with ZERO paid keys if you use Ollama.
# ─────────────────────────────────────────────────────────────────────────────

# --- Core ---
NODE_ENV=development
SITE_NAME="AutoNews AI"
SITE_URL=http://localhost:3000
# Comma-separated admin emails / a single shared admin token for the dashboard.
ADMIN_TOKEN=change-me-to-a-long-random-string

# --- Database (PostgreSQL) ---
# docker-compose spins this up automatically.
DATABASE_URL=postgresql://autonews:autonews@localhost:5432/autonews?schema=public

# --- Redis (BullMQ queue + cache) ---
REDIS_URL=redis://localhost:6379

# --- AI provider selection ---
# One of: ollama | openai | anthropic
# `ollama` = fully free, runs locally. Default for the free MVP.
AI_PROVIDER=ollama

# Ollama (free, local). Pull a model first:  `ollama pull llama3.1`
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# OpenAI (optional, paid)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic (optional, paid)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Trend sources (all optional; RSS + Reddit + Google Trends + HN work key-free) ---
# Reddit public JSON needs no key. To raise rate limits, set a descriptive UA:
REDDIT_USER_AGENT=autonews-ai/0.1 (by /u/yourname)
# NewsAPI.org (optional, free tier available)
NEWSAPI_KEY=
# YouTube Data API v3 (optional)
YOUTUBE_API_KEY=
# X / Twitter API (optional, paid) — left empty disables the X source.
X_BEARER_TOKEN=

# --- Automation behavior ---
# manual = every article waits for admin approval; auto = publish if it passes QA.
PUBLISH_MODE=manual
# Minimum quality score (0-100) required to auto-publish.
MIN_QUALITY_SCORE=70
# How many top-ranked topics to turn into articles per trend cycle.
TOPICS_PER_CYCLE=5
# Cron-style cadence (see worker/scheduler.ts) in minutes.
TREND_INTERVAL_MIN=30
PUBLISH_INTERVAL_MIN=10
